# ==========================
# Database (Neon PostgreSQL)
# ==========================
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# ==========================
# Admin Authentication (Enterprise Security)
# ==========================
ADMIN_EMAIL="admin@youthcamping.in"
ADMIN_PASSWORD="your_secure_password" # Use 16+ chars for production

# ==========================
# URL Configuration
# ==========================
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# ==========================
# Cloudflare Turnstile (Anti-Bot Protection)
# ==========================
# Testing Keys:
# Secret: 1x0000000000000000000000000000000AA
# Site Key: 1x00000000000000000000AA
TURNSTILE_SECRET_KEY="YOUR_TURNSTILE_SECRET_KEY"
NEXT_PUBLIC_TURNSTILE_SITE_KEY="YOUR_TURNSTILE_SITE_KEY"

# ==========================
# Upstash Redis (Rate Limiting & Caching)
# ==========================
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_redis_token"

# ==========================
# Cloudinary (Luxury Media CDN)
# ==========================
NEXT_PUBLIC_CLOUDINARY_CLOUD="your_cloud_name"
NEXT_PUBLIC_CLOUDINARY_PRESET="your_unsigned_preset"

# ==========================
# Phase 8: Payment Gateways (Optional)
# ==========================
STRIPE_SECRET_KEY="sk_test_..."
PAYPAL_CLIENT_ID="your_client_id"